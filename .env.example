DATABASE_URL="postgres://username:password@host.neon.tech/neondb?sslmode=require"
ADMIN_EMAIL="you@example.com"
NEON_AUTH_JWKS_URL="https://your-neon-auth-domain/.well-known/jwks.json"
NEON_AUTH_ISSUER=""
NEON_AUTH_AUDIENCE=""
VITE_NEON_AUTH_URL="https://your-neon-auth-domain"
VITE_NEON_DATA_API_URL="https://your-neon-data-api-domain/rest/v1"

# --- Mayar payment gateway ---
# Get your API key from web.mayar.club (sandbox) or web.mayar.id (production)
# -> Integration -> API Key.
MAYAR_API_KEY=""
# 'sandbox' (default) uses api.mayar.club; 'production' uses api.mayar.id.
MAYAR_ENV="sandbox"
# Optional: explicit API base URL override (wins over MAYAR_ENV).
# MAYAR_API_URL=""
# A random secret string used to authenticate the webhook callback URL.
# Register this URL in the Mayar dashboard:
#   https://<your-site>/api/payments/webhook/<MAYAR_WEBHOOK_TOKEN>
MAYAR_WEBHOOK_TOKEN=""
# Absolute origin of the deployed site, used to build payment redirect URLs.
# In local dev this defaults to the request origin if unset.
PUBLIC_BASE_URL="https://your-site.example.com"
